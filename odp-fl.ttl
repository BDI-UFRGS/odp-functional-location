                       <http://purl.obolibrary.org/obo/BFO_0000196> fl:GasLiquidSeparationFunction_2 ;
                       rdfs:comment "Currently installed (no removal date). Asserted as GasLiquidSeparator (primitive universal, COPPP-style); subsumption entails SeparationEquipment (and iof-constr:MaterialArtifact), supporting CQ6 retrieval. Bears a gas-liquid separation function matching the function required by Spec_V23401 — the prescriptive-realized correspondence queried in CQ6."@en ;
                       rdfs:label "Separator V-23401 v1"@en .

# ----------------------------------------------------------------------------
# CQ4 (verbatim): functional locations requiring gas-liquid separation
#
# SELECT ?loc WHERE {
#   ?spec a fl:FunctionalLocationSpecification ;
#         fl:specifiesLocation ?loc ;
#         fl:requiresFunction ?f .
#   ?f a fl:GasLiquidSeparationFunction .
# }
#
# CQ6 (verbatim): separation equipment + locations whose specs require its
# function kind (prescriptive-realized join; SeparationEquipment instances
# retrieved by subsumption from asserted GasLiquidSeparator typing)
#
# SELECT ?eq ?loc WHERE {
#   ?eq a fl:SeparationEquipment ;
#       <http://purl.obolibrary.org/obo/BFO_0000196> ?bf ;
#       fl:installedAt ?loc .
#   ?bf a ?fkind . ?fkind rdfs:subClassOf* fl:SeparationFunction .
#   ?spec fl:specifiesLocation ?loc ;
#         fl:requiresFunction ?rf .
#   ?rf a ?fkind .
# }
# ----------------------------------------------------------------------------

#################################################################
#    Camera-ready additions (FOIS 2026)
#    - DeckC delimiting structure (Sec 5.2 / 7.1)
#    - IOF Core alignment axioms (Sec 5.4 / Fig. 1 caption) -- FLAGGED
#    - Source-layer data exercised by CQ7 (Sec 7.2; src: namespace)
#    (V-23401 coordinates and the hierarchy fix were applied inline above.)
#################################################################

# ── Delimiting structure for the PT-23424 position (Sec 5.2 / 7.1) ───────────
# Instantiates the individual already named in the skos:example on
# fl:hasBoundaryDeterminedBy, giving the FunctionalLocation existential
# restriction (hasBoundaryDeterminedBy some BFO_0000030) a concrete filler and
# making the dataset match the paper's prose. Typed BFO_0000030 (Object) to
# satisfy the restriction range with certainty; also typed iof-constr:MaterialArtifact
# to match Sec 5.2's wording (subject to the same IRI check as the axioms below).
fl:DeckC_Structure rdf:type owl:NamedIndividual ,
                            <http://purl.obolibrary.org/obo/BFO_0000030> ,
                            iof-constr:MaterialArtifact ;
                   rdfs:label "Deck C mounting structure (PT-23424)"@en ,
                              "Estrutura de montagem do Deck C (PT-23424)"@pt-br ;
                   rdfs:comment "Aggregated mounting brackets, nozzle flanges, and deck frame that jointly delimit the PT-23424 transmitter position."@en ,
                                "Suportes de montagem, flanges de bocais e a estrutura do deck que conjuntamente delimitam a posição do transmissor PT-23424."@pt-br .

fl:FL_PT23424_Site fl:hasBoundaryDeterminedBy fl:DeckC_Structure .


# ── IOF Core 202602 alignment (Sec 5.4 and Fig. 1 caption) ─────────────────
# Verified against Release_202602: MaterialArtifact = iof-constr:MaterialArtifact
# iof-av: prefix updated to .../annotation/ (202602); maturity replaces maturityLevel;
# Provisional/Released moved to iof-ind: namespace. The IOF Maintenance dependency
# was decoupled into the optional extension odp-fl-maint.ttl (v0.7).

# Already entailed once BFO is imported (bfo:Site is immaterial, MaterialArtifact
# is material), asserted explicitly so the Fig. 1 caption "declared disjoint with
# iof:MaterialArtifact" is literally true in the artifact.
fl:FunctionalLocation owl:disjointWith iof-constr:MaterialArtifact .


# ── Source-layer data for CQ7 (NOT part of the ODP -- see Sec 7.2) ───────────
# Production events come from the source schemas the pattern integrates OVER, not
# from the ODP itself. Modeled in a separate 'src:' namespace so the boundary is
# explicit in the artifact: the shared fl:FunctionalLocation site is the ONLY join
# key between src: and fl:. If you keep this, update cqs/cq7.rq to query
# src:affectsLocation (add the src: PREFIX).
src:ProductionLossEvent rdf:type owl:Class ;
                        rdfs:label "Production loss event (source schema)"@en ;
                        rdfs:comment "Source-schema class, external to the Functional Location ODP. Included only to demonstrate cross-source integration via the shared site (CQ7)."@en .

src:affectsLocation rdf:type owl:ObjectProperty ;
                    rdfs:range fl:FunctionalLocation ;
                    rdfs:label "affects location"@en ;
                    rdfs:comment "Source-schema relation from a production event to the functional locations it affects. Not part of the ODP; the ODP contributes only the site as integration key."@en .

src:eventDate rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:date ;
              rdfs:label "event date"@en .

src:E_2024_15 rdf:type owl:NamedIndividual ,
                       src:ProductionLossEvent ;
              src:affectsLocation fl:FL_PT23424_Site ,
                                  fl:FL_V23401_Site ;
              src:eventDate "2024-07-03"^^xsd:date ;
              rdfs:label "Production Loss Event E-2024-15"@en ;
              rdfs:comment "Pressure anomaly at PT-23424; associated separator V-23401 taken offline for inspection."@en .


