#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( fl:EquipmentUnitSite
                fl:MaintainableItemSite
                fl:PlantSite
                fl:SubsystemSite
                fl:SystemSite
              )
] .

